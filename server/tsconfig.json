{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "types": ["bun-types"],
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "src",
    "paths": {
      "@open-retro/shared": ["../shared/dist/index.d.ts"],
      "@open-retro/shared/*": ["../shared/dist/*"]
    }
  },
  "include": ["src"]
}

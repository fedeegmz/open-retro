{
  "name": "@open-retro/server",
  "version": "0.0.6",
  "files": [
    "dist"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "bun --watch src/bin.ts",
    "start": "bun src/bin.ts",
    "build": "bun build src/index.ts --outdir ./dist --target bun && tsc --emitDeclarationOnly"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@open-retro/shared": "*",
    "elysia": "^1.4.27"
  },
  "devDependencies": {
    "bun-types": "^1.3.10"
  }
}
